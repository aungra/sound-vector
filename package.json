{
  "name": "sound-vector",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/demo run dev",
    "build": "npm --workspace apps/demo run build",
    "start": "npm --workspace apps/demo run start",
    "audio-server": "npm --workspace apps/demo run audio-server",
    "genre-collect": "npm --workspace apps/demo run genre-collect",
    "genre-train": "npm --workspace apps/demo run genre-train",
    "test": "npm --workspace packages/reversible-svg run test",
    "typecheck": "npm --workspace apps/demo run typecheck",
    "check": "npm run test && npm run typecheck && npm run build"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  }
}
